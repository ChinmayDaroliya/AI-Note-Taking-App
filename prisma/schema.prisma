generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url = env("DATABASE_URL")
}

model Note {
    id             string      @id @default(cuid())
    title          string      
    content        string
    tags           string[]
    user_id        string
    created_at     DateTime    @default(now())
    updated_at     DateTime    @updatedAt

    @@map("notes")   
 }

 model Profile{
    id             string       @id @default(cuid())
    user_id        string       @unique
    display_name   string?
    avatar_url     string?
    created_at     DateTime     @default(now())
    updated_at     DateTime     @updatedAt

    @@map("profiles")
 }