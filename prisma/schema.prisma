generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Note {
  id         String   @id @default(cuid())
  title      String
  content    String
  tags       String[]
  user_id    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("notes")
}

model Profile {
  id           String   @id @default(cuid())
  user_id      String   @unique
  display_name String?
  avatar_url   String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("profiles")
}
